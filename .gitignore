# Secrets — NEVER commit
.env
.env.*
!.env.example

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/
venv/

# Test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Pipeline output dirs (contain local paths, not source)
migrated/
migrated_aca/

# Archived code/docs — kept locally, removed from the repo
/archive/

# Presentation files — keep in local only
*.pptx
*.docx

# macOS
.DS_Store

# IDE — keep .vscode/settings.json but drop the rest
.idea/
.vscode/*
!.vscode/settings.json

# Terraform (adapters/*/infra)
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
**/.build/

# Generated guardrail report (scripts/demo_agents.py --html)
galaxy-guardrail-report.html
*-guardrail-report.html
# ...but keep the one committed reference report (live AWS run) linked from the docs
!docs/aws-guardrail-report.html
docs/output/
