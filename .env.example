# Galaxy SDLC — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── Azure resource group / subscription ───────────────────────────────────────
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ── Azure OpenAI (via APIM — recommended) ─────────────────────────────────────
# Route through APIM so the real AOAI key never leaves the Azure control plane.
# Get the sub-key from: az keyvault secret show --vault-name <your-kv> \
#   --name apim-subscription-key --query value -o tsv
APIM_ENDPOINT=https://<your-apim>.azure-api.net
APIM_SUBSCRIPTION_KEY=<apim-subscription-key>

# ── Azure OpenAI (direct — used only if APIM_ENDPOINT is unset) ───────────────
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_KEY=<your-aoai-key>

# ── Observability ─────────────────────────────────────────────────────────────
# Get from: az keyvault secret show --vault-name <your-kv> \
#   --name appinsights-connection-string --query value -o tsv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
OTEL_SERVICE_NAME=galaxy-migration-local

# ── Key Vault ─────────────────────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://<your-keyvault>.vault.azure.net/

# ── Postgres hash-chain ledger (optional — stdout mode if blank) ──────────────
# POSTGRES_DSN=postgresql://user:pass@<your-pg>.postgres.database.azure.com:5432/ledger

# ── NHI Client IDs ────────────────────────────────────────────────────────────
# Set to the client IDs of your Managed Identity service principals.
# Create one MI per agent:
#   az identity create --name galaxy-<agent>-mi --resource-group <rg>
#   az identity show  --name galaxy-<agent>-mi --resource-group <rg> --query clientId -o tsv

# Shared
NHI_CLIENT_ID_CLASSIFIER=<your-client-id>

# Migration pipeline
NHI_CLIENT_ID_SCANNER=<your-client-id>
NHI_CLIENT_ID_ASTANALYZER=<your-client-id>
NHI_CLIENT_ID_ANALYZER=<your-client-id>
NHI_CLIENT_ID_LAMBDAANALYZER=<your-client-id>
NHI_CLIENT_ID_ARCHITECT=<your-client-id>
NHI_CLIENT_ID_CODER=<your-client-id>
NHI_CLIENT_ID_REVIEWER=<your-client-id>
NHI_CLIENT_ID_SECURITY=<your-client-id>
NHI_CLIENT_ID_SECURITYREVIEWER=<your-client-id>
NHI_CLIENT_ID_TESTER=<your-client-id>
NHI_CLIENT_ID_IACGEN=<your-client-id>
NHI_CLIENT_ID_SLOWATCHER=<your-client-id>

# Discovery pipeline
NHI_CLIENT_ID_DISCOVERYSCANNER=<your-client-id>
NHI_CLIENT_ID_DISCOVERYGRAPHER=<your-client-id>
NHI_CLIENT_ID_DISCOVERYBRD=<your-client-id>
NHI_CLIENT_ID_DISCOVERYARCHITECT=<your-client-id>
NHI_CLIENT_ID_DISCOVERYSTORIES=<your-client-id>
