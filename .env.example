# Galaxy Agentic Governance Platform — environment template
# Copy to .env and fill in the cloud you're running. NEVER commit .env.
#
# demo_agents.py loads .env automatically. Model selection is per-cloud: --azure /
# --gcp / --aws call their REAL model when the block below resolves; otherwise (or
# with --fake / --local) the deterministic fake model runs. Fill in only the
# cloud(s) you use; everything else can stay blank/commented.

# ══ AZURE — demo_agents.py (default) → Azure OpenAI ═════════════════════════════
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# Use a dated version (e.g. 2025-03-01-preview), not "preview". Reasoning/codex
# deployments (o-series, gpt-5*, *-codex) need 2025-03-01-preview+ and auto-route
# through the Responses API.
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_KEY=<your-aoai-key>
# Force the Responses API on/off (default: auto-detect from the deployment name):
# AZURE_OPENAI_USE_RESPONSES_API=1
# Optional — route through APIM instead of direct AOAI (egress chokepoint):
# APIM_ENDPOINT=https://<your-apim>.azure-api.net
# APIM_SUBSCRIPTION_KEY=<apim-subscription-key>

# ══ GCP — demo_agents.py --gcp → Vertex AI / Gemini  (needs: pip install '.[gcp]') ══
# Vertex via ADC: set the project + `gcloud auth application-default login`.
GOOGLE_CLOUD_PROJECT=<your-gcp-project>
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-pro
GOOGLE_GENAI_USE_VERTEXAI=True
# Gemini Developer API instead of Vertex/ADC (set a key, omit the project above):
# GOOGLE_API_KEY=<your-gemini-api-key>

# ══ AWS — demo_agents.py --aws → Bedrock via API Gateway  (needs: pip install '.[aws]') ══
# Provision the infra first: cd adapters/aws/infra && terraform apply (tagged galaxy-rp),
# then copy `terraform output` here. The agent reaches Bedrock ONLY through the API
# Gateway chokepoint (x-api-key) — it never holds Bedrock credentials.
AWS_REGION=us-east-1
AWS_PROFILE=<your-sso-profile>                 # or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6              # terraform output bedrock_model_id
AWS_BEDROCK_GATEWAY_ENDPOINT=https://<api-id>.execute-api.us-east-1.amazonaws.com/prod/invoke   # output bedrock_gateway_url
# The gateway x-api-key — env fallback (no boto3 needed), or pull from Secrets Manager:
#   aws secretsmanager get-secret-value --secret-id galaxy/bedrock-gateway-key --query SecretString -o text
AWS_BEDROCK_GATEWAY_KEY=<gateway-api-key>
GALAXY_LEDGER_TABLE=galaxy-trace-ledger        # DynamoDB ledger (stdout mode if absent)

# ══ Per-agent NHI identity (the 3 demo agents) ═════════════════════════════════
# Each agent's cloud principal id — Azure→Entra clientId, AWS→IAM role ARN, GCP→SA
# email. Placeholders are fine offline; the registry resolves NHI_CLIENT_ID_<AGENT>
# for whatever agent types you run (no hardcoded list). Add more as you add agents.
NHI_CLIENT_ID_FINOPS=<finops-principal-id>
NHI_CLIENT_ID_AUDITOR=<auditor-principal-id>
NHI_CLIENT_ID_ROGUE=<rogue-principal-id>

# ══ Observability + ledger (optional — stdout / no-op if blank) ════════════════
OTEL_SERVICE_NAME=galaxy-governance-local
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
# AZURE_KEY_VAULT_URL=https://<your-keyvault>.vault.azure.net/
# POSTGRES_DSN=postgresql://user:pass@<your-pg>.postgres.database.azure.com:5432/ledger
