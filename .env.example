# Galaxy SDLC — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── Azure resource group / subscription ───────────────────────────────────────
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ── Azure OpenAI (via APIM — recommended) ─────────────────────────────────────
# Route through APIM so the real AOAI key never leaves the Azure control plane.
# Get the sub-key from: az keyvault secret show --vault-name <your-kv> \
#   --name apim-subscription-key --query value -o tsv
APIM_ENDPOINT=https://<your-apim>.azure-api.net
APIM_SUBSCRIPTION_KEY=<apim-subscription-key>

# ── Azure OpenAI (direct — `demo_agents.py` azure mode uses these for REAL calls) ─
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# Use a dated version (e.g. 2025-03-01-preview). Reasoning/codex deployments
# (o-series, gpt-5*, *-codex) need 2025-03-01-preview+; the demo auto-bumps to
# that floor and routes them through the Responses API.
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_KEY=<your-aoai-key>
# Force the Responses API on/off (default: auto-detect from deployment name).
# AZURE_OPENAI_USE_RESPONSES_API=1

# ── GCP Vertex AI / Gemini (`demo_agents.py --gcp` uses these for REAL calls) ──
# Needs the .[gcp] extra: pip install '.[gcp]' (langchain-google-vertexai / -genai).
# Vertex (ADC): set the project (auth via `gcloud auth application-default login`).
GOOGLE_CLOUD_PROJECT=<your-gcp-project>
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-pro
# Gemini Developer API alternative (instead of Vertex/ADC): set a key, omit project.
# GOOGLE_API_KEY=<your-gemini-api-key>

# ── AWS Bedrock via API Gateway (`demo_agents.py --aws` uses these for REAL calls) ─
# Provision the infra first: cd adapters/aws/infra && terraform apply, then copy
# `terraform output` here. The agent reaches Bedrock ONLY through the API Gateway
# chokepoint (x-api-key) — it never holds Bedrock credentials.
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0   # terraform output bedrock_model_id
AWS_BEDROCK_GATEWAY_ENDPOINT=https://<api-id>.execute-api.us-east-1.amazonaws.com/prod/invoke  # output bedrock_gateway_url
# The gateway x-api-key: pull from Secrets Manager (needs .[aws]/boto3 + AWS creds), OR
# paste it here for the env fallback (no boto3 needed):
#   aws secretsmanager get-secret-value --secret-id galaxy/bedrock-gateway-key --query SecretString -o text
AWS_BEDROCK_GATEWAY_KEY=<gateway-api-key>
GALAXY_LEDGER_TABLE=galaxy-trace-ledger
# Per-agent NHI role ARNs (terraform output agent_role_arns) — the agents' NHI ids:
# NHI_CLIENT_ID_FINOPS=arn:aws:iam::<acct>:role/galaxy-rp-finops
# NHI_CLIENT_ID_AUDITOR=arn:aws:iam::<acct>:role/galaxy-rp-auditor
# NHI_CLIENT_ID_ROGUE=arn:aws:iam::<acct>:role/galaxy-rp-rogue

# ── Observability ─────────────────────────────────────────────────────────────
# Get from: az keyvault secret show --vault-name <your-kv> \
#   --name appinsights-connection-string --query value -o tsv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
OTEL_SERVICE_NAME=galaxy-migration-local

# ── Key Vault ─────────────────────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://<your-keyvault>.vault.azure.net/

# ── Postgres hash-chain ledger (optional — stdout mode if blank) ──────────────
# POSTGRES_DSN=postgresql://user:pass@<your-pg>.postgres.database.azure.com:5432/ledger

# ── NHI Client IDs (per agent — one var per agent type) ─────────────────────
# The registry hardcodes NO agent list: it resolves `NHI_CLIENT_ID_<AGENT_TYPE>`
# for whatever agent types you run. Set each to the agent's cloud principal id —
# sourced from your cloud directory:
#   Azure → Entra App Registration / User-Assigned MI clientId
#     az identity create --name galaxy-<agent>-mi --resource-group <rg>
#     az identity show  --name galaxy-<agent>-mi --resource-group <rg> --query clientId -o tsv
#   AWS   → IAM role ARN   (or omit and set AWS_ACCOUNT_ID to use the
#                           arn:aws:iam::<acct>:role/galaxy-<agent> convention)
#   GCP   → Service Account email
#
# The demo payload's three agents (offline defaults set in payload_agents/__init__):
NHI_CLIENT_ID_FINOPS=<your-client-id>
NHI_CLIENT_ID_AUDITOR=<your-client-id>
NHI_CLIENT_ID_ROGUE=<your-client-id>
# …add NHI_CLIENT_ID_<AGENT_TYPE> for any other agent you deploy.
