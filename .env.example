# Galaxy SDLC — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── Azure OpenAI (via APIM) ───────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://galaxyscanner-apim.azure-api.net/openai
AZURE_OPENAI_API_KEY=<apim-subscription-key-from-portal>
AZURE_OPENAI_DEPLOYMENT=gpt-5-3-codex
AZURE_OPENAI_API_VERSION=preview

# ── Observability ─────────────────────────────────────────────────────────────
# Get from: az keyvault secret show --vault-name galaxyscanner-kv-d63cdd \
#           --name appinsights-connection-string --query value -o tsv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://eastus-8.in.applicationinsights.azure.com/

# ── Key Vault ─────────────────────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://galaxyscanner-kv-d63cdd.vault.azure.net/

# ── Postgres hash-chain ledger (optional — stdout mode if blank) ───────────────
# POSTGRES_DSN=postgresql://user:pass@galaxyscanner-pg.postgres.database.azure.com:5432/ledger

# ── NHI Client IDs (real Entra Managed Identity client IDs — not secrets) ────
# These are baked into core/nhi_identity.py as defaults. Override here only if
# you need to point at different registrations (e.g. a test tenant).

# Shared
NHI_CLIENT_ID_CLASSIFIER=c4be541a-a1f2-433c-8166-9ebcf2d87b78

